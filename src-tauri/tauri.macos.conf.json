{
  "app": {
    "windows": [
      {
        "title": "YTubic",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 14, "y": 12 },
        "resizable": true,
        "center": true,
        "backgroundColor": "#0a0a0a",
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "targets": ["app"],
    "createUpdaterArtifacts": false
  }
}
